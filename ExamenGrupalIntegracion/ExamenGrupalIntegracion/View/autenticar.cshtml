Autenticar.cshtml

@{
    ViewBag.Title = "Autenticar";
}
 
<!DOCTYPE html>
 
<html>
<head>
<meta name="viewport" content="width=device-width" />
<title></title>
<link href="~/Content/css/Autenticar.css" rel="stylesheet" />
 
    </head>
<body>
<form action="@Url.Action("Autenticar","Acceso")" method="post">
<h1>Acceso para Empleados</h1>
<div class="inset">
<p>
<label for="email">USUARIO</label>
<input type="text" name="correo" id="correo">
</p>
<p>
<label for="password">CLAVE</label>
<input type="password" name="clave" id="clave">
</p>
 
            </div>
<p class="p-container">
<span>@Html.ActionLink("Registrar", "Registro", "Acceso", new { area = "" }, new { @class = "nav-link" })</span>
<input type="submit" value="Log in">
</p>
 
        </form>
</body>
</html>